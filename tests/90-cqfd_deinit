#!/usr/bin/env bash
#
# validate the behavior of deinit command

. "$(dirname "$0")/jtest.inc" "$1"

cd "$TDIR/" || exit 1

jtest_prepare "run cqfd deinit with a proper .cqfdrc should pass"
if cqfd deinit; then
	jtest_result pass
else
	jtest_result fail
fi

# backup cqfdrc
cp .cqfdrc .cqfdrc.orig

jtest_prepare "run cqfd deinit with a nonexisting Dockerfile should fail"
sed -e "s/\[build\]/[build]\ndistro='thisshouldfail'/" -i .cqfdrc
if ! cqfd deinit; then
	jtest_result pass
else
	jtest_result fail
fi

jtest_prepare "run cqfd deinit with another Dockerfile should pass"
sed -e "s/thisshouldfail/centos/" -i .cqfdrc
if cqfd init && cqfd deinit; then
	jtest_result pass
else
	jtest_result fail
fi

# restore .cqfdrc
mv .cqfdrc.orig .cqfdrc

jtest_prepare "run cqfd deinit with an already deinit'ed image should fail"
if ! cqfd deinit; then
	jtest_result pass
else
	jtest_result fail
fi
