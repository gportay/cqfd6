#!/usr/bin/env bash
#
# validate the behavior of deinit with docker extra rmi arguments

. "$(dirname "$0")/jtest.inc" "$1"

cd "$TDIR/" || exit 1

jtest_prepare "run cqfd deinit with CQFD_EXTRA_RMI_ARGS=--force should pass"
if CQFD_EXTRA_RMI_ARGS="--force" cqfd deinit; then
	jtest_result pass
else
	jtest_result fail
fi

# backup .cqfdrc
mv .cqfdrc .cqfdrc.orig

jtest_prepare "run cqfd deinit with build_docker_rmi_args=--force should pass"
sed -e '/\[build\]/abuild_docker_rmi_args="--force"' .cqfdrc.orig >.cqfdrc
if cqfd deinit; then
	jtest_result pass
else
	jtest_result fail
fi

# restore .cqfdrc
mv .cqfdrc.orig .cqfdrc
