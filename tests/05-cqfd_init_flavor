#!/usr/bin/env bash
#
# validate the behavior of init command with flavors

set -o pipefail

. "$(dirname "$0")/jtest.inc" "$1"
flavor="foo"

cd "$TDIR/" || exit 1

################################################################################
# 'cqfd init' with different flavor makes a different container
################################################################################
cp -f Cqfdfile Cqfdfile.orig
sed -i -e "s/\[foo\]/[foo]\ndistro='centos'/" Cqfdfile

jtest_prepare "cqfd init using '$flavor' flavor"
if cqfd -b "$flavor" init && \
   cqfd -b "$flavor" run "grep '^NAME=' /etc/os-release" | grep "^NAME=\"CentOS Linux\"$"; then
	jtest_result pass
else
	jtest_result fail
fi
# restore initial Cqfdfile
mv -f Cqfdfile.orig Cqfdfile

################################################################################
# 'cqfd init' with invalid flavor should fail
################################################################################
flavorPart="${flavor:0:2}"
jtest_prepare "cqfd init using part of '$flavor' flavor should fail"
if ! cqfd -b "$flavorPart" init; then
	jtest_result pass
else
	jtest_result fail
fi

################################################################################
# 'cqfd init' without flavor generates our regular container
################################################################################
jtest_prepare "cqfd init without flavor"
if cqfd init &&
   cqfd run "grep '^NAME=' /etc/os-release" | grep "^NAME=\"Ubuntu\"$"; then
	jtest_result pass
else
	jtest_result fail
fi
